<view class="calendar-container {{isVisible ? 'calendar-visible' : ''}}">
  <!-- 顶部返回按钮和月份导航 -->
  <view class="calendar-header">
    <view class="back-btn" bindtap="handleBack">
      <text class="back-icon">←</text>
      <text class="back-text">返回</text>
    </view>
    <!-- 月份导航 -->
    <view class="month-nav">
      <view class="nav-btn" bindtap="prevMonth">
        <text class="nav-icon">←</text>
      </view>
      <text class="month-text">{{currentYear}}年{{currentMonth}}月</text>
      <view class="nav-btn" bindtap="nextMonth">
        <text class="nav-icon">→</text>
      </view>
    </view>
  </view>

  <!-- 日历内容 -->
  <view class="calendar-content">
    <!-- 星期表头 -->
    <view class="week-header">
      <text class="week-day">日</text>
      <text class="week-day">一</text>
      <text class="week-day">二</text>
      <text class="week-day">三</text>
      <text class="week-day">四</text>
      <text class="week-day">五</text>
      <text class="week-day">六</text>
    </view>

    <!-- 日历网格 -->
    <view class="calendar-grid">
      <view
        wx:for="{{calendarDays}}"
        wx:key="index"
        class="calendar-day {{item.type}} {{item.isToday ? 'today' : ''}}"
        bindtap="viewRecord"
        data-day="{{item.day}}"
        data-year="{{item.year}}"
        data-month="{{item.month}}"
        wx:if="{{item.day}}"
      >
        <text class="day-number">{{item.day}}</text>
        <view class="record-dots" wx:if="{{item.recordCount > 0}}">
          <view
            wx:for="{{item.recordCount}}"
            wx:key="dotIndex"
            class="record-dot"
          ></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 记录详情弹窗 -->
  <view class="record-popup" wx:if="{{showPopup}}">
    <!-- 遮罩层 -->
    <view class="popup-overlay" bindtap="closePopup"></view>

    <!-- 信笺卡片 -->
    <view class="popup-content">
      <!-- 头部 -->
      <view class="popup-header">
        <text class="popup-date">{{currentRecordDate}}</text>
        <view class="popup-close" bindtap="closePopup">×</view>
      </view>

      <!-- 可滑动内容区域 -->
      <scroll-view scroll-y="true" class="popup-scroll">
        <view class="record-list">
          <view
            wx:for="{{currentRecords}}"
            wx:key="index"
            class="record-item"
          >
            <!-- 用户文字 -->
            <view class="record-text">{{item.text}}</view>

            <!-- 图片 -->
            <view class="record-image" wx:if="{{item.hasImage && item.imagePath}}">
              <image class="record-img" src="{{item.imagePath}}" mode="aspectFit"></image>
            </view>

            <!-- 治愈语录 -->
            <view class="record-quote" wx:if="{{item.quote.text}}">
              <text class="quote-text">{{item.quote.text}}</text>
              <text class="quote-source">—— {{item.quote.from}}</text>
            </view>

            <!-- 分隔线 -->
            <view class="record-divider" wx:if="{{index < currentRecords.length - 1}}"></view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>