/* components/comp-write/comp-write.wxss */
.comp-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 999;
  opacity: 0;
  transform: translateX(-100%);
  transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  background-color: #f5f5f5;
}

.comp-visible {
  opacity: 1;
  transform: translateX(0);
}

/* 顶部返回按钮 */
.comp-header {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  padding: 40rpx 0;
  padding-left: 40rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-bottom: 1rpx solid #eee;
  z-index: 10;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.back-icon {
  font-size: 48rpx;
  line-height: 1;
}

/* 内容区域 */
.content {
  position: absolute;
  top: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 90%;
  max-width: 750rpx;
  padding: 40rpx;
  background-color: white;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
  min-height: 600rpx;
}

/* 杂志卡片 - 垂直流式排版 */
.magazine-card {
  position: relative;
  background-color: #FFF9F0;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
  min-height: 500rpx;
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center; /* 整体垂直居中 */
}

/* 时间戳 */
.timestamp {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  font-size: 24rpx;
  color: #8B4513;
  font-weight: 500;
  z-index: 2;
}

/* 无图片模式布局 - 垂直流式 */
.no-image-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
  gap: 40rpx;
  z-index: 2;
  position: relative;
}

.user-text-center {
  text-align: center;
  width: 100%;
  max-width: 600rpx;
}

.quote-content-center {
  text-align: center;
  width: 100%;
  max-width: 600rpx;
}

/* 有图片模式布局 - 垂直流式 */
.has-image-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
  gap: 40rpx;
  z-index: 2;
  position: relative;
}

.user-text-top {
  text-align: center;
  width: 100%;
  max-width: 600rpx;
}

.core-image {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
}

/* 拍立得照片 */
.polaroid-frame {
  position: relative;
  background-color: white;
  padding: 20rpx;
  border-radius: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  max-width: 400rpx;
  max-height: 400rpx;
}

.polaroid-img {
  width: 100%;
  height: 100%;
  border-radius: 4rpx;
}

.polaroid-caption {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
  text-align: center;
}

.quote-content-bottom {
  text-align: center;
  width: 100%;
  max-width: 600rpx;
}

/* 默认装饰图 */
.placeholder-zen {
  width: 300rpx;
  height: auto;
  object-fit: contain;
}

/* 治愈语录 */
.quote-text {
  font-size: 28rpx;
  color: #7FB2E5;
  font-weight: 500;
  line-height: 1.6;
  display: block;
  margin-bottom: 10rpx;
}

.quote-source {
  font-size: 24rpx;
  color: #7FB2E5;
  line-height: 1.5;
  display: block;
}

/* 输入区域 */
.input-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  font-size: 36rpx;
  color: #5D4037;
  border: none;
  border-radius: 8rpx;
  background-color: transparent;
  box-sizing: border-box;
  line-height: 1.6;
  font-family: serif;
  text-align: center;
}

.input-textarea:focus {
  outline: none;
}

/* 操作区域 */
.actions {
  position: relative;
  z-index: 2;
}

/* 抽取金句按钮 */
.pet-quote-section {
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.pet-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.pet-avatar .avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.quote-btn {
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 16rpx;
  background-color: #ffd700;
  color: #333;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.btn-disabled {
  background-color: #ccc;
  color: #666;
  pointer-events: none;
}

.btn-enabled:active {
  background-color: #ffc700;
  transform: scale(0.98);
}

/* 图片选择区域 */
.image-section {
  margin-bottom: 40rpx;
}

.choose-btn {
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  color: #333;
  background-color: #f8f9fa;
  border: 2rpx solid #ddd;
  border-radius: 16rpx;
}

.choose-btn:active {
  background-color: #e9ecef;
}

.clear-btn {
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  color: #666;
  background-color: #f8f9fa;
  border: 2rpx solid #ddd;
  border-radius: 16rpx;
}

.clear-btn:active {
  background-color: #e9ecef;
}

/* 文字闪光按钮 - 物理层解封 */
.btn-text-export {
  flex: 1;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 16rpx;
  background-color: #ffd700;
  color: #333;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  pointer-events: auto !important;
  z-index: 99;
  position: relative;
}

.btn-text-export:active {
  background-color: #ffc700;
  transform: scale(0.98);
}

/* 保存到日历按钮 */
.save-calendar-section {
  margin-bottom: 20rpx;
}

.btn-save-calendar {
  width: 100%;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 20rpx;
  background-color: #FFD700;
  color: #5D4037;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.btn-save-calendar:active {
  background-color: #FFC700;
  transform: scale(0.98);
}

/* 保存按钮区域 */
.save-section {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.save-btn {
  flex: 1;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 16rpx;
  background-color: #ffd700;
  color: #333;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.save-btn.btn-disabled {
  background-color: #ccc;
  color: #666;
  pointer-events: none;
}

.save-btn.btn-enabled:active {
  background-color: #ffc700;
  transform: scale(0.98);
}

/* 隐藏 Canvas 区域 */
.hidden-canvas {
  position: absolute;
  left: -9999rpx;
  top: -9999rpx;
  width: 750rpx;
  height: 1000rpx;
  z-index: -1;
}

/* 海报预览弹窗 */
.poster-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.overlay-visible {
  opacity: 1;
  pointer-events: auto;
}

.poster-container {
  position: relative;
  width: 90%;
  max-width: 750rpx;
  background-color: white;
  border-radius: 16rpx;
  overflow: hidden;
  padding: 40rpx;
  box-sizing: border-box;
}

.close-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  z-index: 10;
}

/* 海报卡片 */
.poster-card {
  position: relative;
  background-color: #FFF9F0;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
  min-height: 500rpx;
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center; /* 整体垂直居中 */
}

/* 海报操作按钮 */
.poster-actions {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.action-btn.secondary {
  background-color: #f8f9fa;
  color: #666;
  border: 2rpx solid #ddd;
}

.action-btn.secondary:active {
  background-color: #e9ecef;
  transform: scale(0.98);
}

.action-btn.primary {
  background-color: #ffd700;
  color: #333;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.action-btn.primary:active {
  background-color: #ffc700;
  transform: scale(0.98);
}