/* 页面容器 */
.page-container {
  width: 100%;
  height: 100vh;
  overflow: hidden;
  position: relative;
  background-color: #f6f6f6;
}

/* 背景图片 */
.background-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 淡入淡出动画 */
.fade-animation {
  opacity: 0;
  transition: opacity 0.8s ease-in-out;
}

/* 左侧标签栏 */
.sidebar {
  position: fixed;
  left: 40rpx;
  top: 200rpx;
  width: 160rpx;
  height: 600rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-around;
  z-index: 100;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(15px);
}

.sidebar-item {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.sidebar-item image {
  width: 100%;
  height: 100%;
}

.sidebar-item.active {
  background-color: rgba(255, 255, 255, 0.6);
}

.sidebar-item:active {
  transform: scale(0.92);
}

/* 天气切换按钮 */
.weather-switch-container {
  position: fixed;
  right: 40rpx;
  bottom: 40rpx;
  z-index: 100;
}

.weather-switch-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
}

.weather-switch-btn image {
  width: 100%;
  height: 100%;
}